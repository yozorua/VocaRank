# VocaRank Configuration
# Rename this file to .env and fill in your keys.

# Comma-separated list of YouTube API keys for general updates (all songs).
# If one key hits quota limit, the script will automatically rotate to the next one.
YOUTUBE_KEYS_GENERAL=

# Comma-separated list of dedicated YouTube API keys for frequent updates of popular songs (views >= 100k).
YOUTUBE_KEYS_POPULAR=

# --- Authentication ---
# Google OAuth Client Credentials (from Google Cloud Console)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Secret keys for signing tokens
# Generate a secure string (e.g., `openssl rand -base64 32`)
AUTH_SECRET=
JWT_SECRET=

# NextAuth Configuration
# The base URL of your website (e.g. http://localhost:3000 for local dev)
NEXTAUTH_URL=
DATABASE_URL=postgresql://vocarank:<your_password>@localhost/vocarank
